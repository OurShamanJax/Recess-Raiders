; Engine configuration file.
; Recess Raiders — 3D schoolyard team capture-and-raid game.
; Godot 4.6.3

config_version=5

[application]

config/version="1.0"
config/name="Recess Raiders"
config/description="3D team capture-the-ball arcade game."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"

[autoload]

Events="*res://scripts/autoload/Events.gd"
GameState="*res://scripts/autoload/GameState.gd"
Config="*res://scripts/autoload/Config.gd"
Settings="*res://scripts/autoload/Settings.gd"
AudioManager="*res://scripts/autoload/AudioManager.gd"
CharacterDefs="*res://scripts/autoload/CharacterDefs.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

